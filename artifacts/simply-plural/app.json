{
  "expo": {
    "name": "Simply Plural",
    "slug": "simply-plural",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "simply-plural",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1117"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "backgroundColor": "#0D1117"
    },
    "web": {
      "output": "static",
      "bundler": "metro",
      "favicon": "./assets/images/icon.png",
      "backgroundColor": "#0D1117",
      "themeColor": "#4ECDC4",
      "name": "Simply Plural",
      "shortName": "SimplyPlural",
      "description": "Track your plural system members and fronting history",
      "lang": "en",
      "scope": "/",
      "startUrl": "/",
      "display": "standalone",
      "orientation": "portrait"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
